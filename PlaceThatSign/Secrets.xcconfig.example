// Copy this file to Secrets.xcconfig and fill in the values from
// your Supabase project (Dashboard -> Project Settings -> API).
// Secrets.xcconfig is gitignored; this example file is checked in.

SUPABASE_URL = https:/$()/YOUR-PROJECT-REF.supabase.co
SUPABASE_ANON_KEY = sb_publishable_XXXXXXXXXXXXXXXXXXXXXXXX

INFOPLIST_KEY_SUPABASE_URL = $(SUPABASE_URL)
INFOPLIST_KEY_SUPABASE_ANON_KEY = $(SUPABASE_ANON_KEY)
